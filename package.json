{
	"name": "@anvilkit/plugin-asset-manager",
	"version": "0.1.11",
	"description": "Headless asset manager plugin for Anvilkit Studio with host-provided uploads and optional React UI.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/cjs/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./ui": {
			"import": {
				"types": "./dist/ui/index.d.ts",
				"default": "./dist/ui/index.js"
			},
			"require": {
				"types": "./dist/cjs/ui/index.d.cts",
				"default": "./dist/ui/index.cjs"
			}
		},
		"./testing": {
			"import": {
				"types": "./dist/testing/index.d.ts",
				"default": "./dist/testing/index.js"
			},
			"require": {
				"types": "./dist/cjs/testing/index.d.cts",
				"default": "./dist/testing/index.cjs"
			}
		},
		"./retry": {
			"import": {
				"types": "./dist/utils/retry.d.ts",
				"default": "./dist/utils/retry.js"
			},
			"require": {
				"types": "./dist/cjs/utils/retry.d.cts",
				"default": "./dist/utils/retry.cjs"
			}
		},
		"./session-store": {
			"import": {
				"types": "./dist/utils/upload-session-store.d.ts",
				"default": "./dist/utils/upload-session-store.js"
			},
			"require": {
				"types": "./dist/cjs/utils/upload-session-store.d.cts",
				"default": "./dist/utils/upload-session-store.cjs"
			}
		},
		"./transform": {
			"import": {
				"types": "./dist/utils/query-param-transform.d.ts",
				"default": "./dist/utils/query-param-transform.js"
			},
			"require": {
				"types": "./dist/cjs/utils/query-param-transform.d.cts",
				"default": "./dist/utils/query-param-transform.cjs"
			}
		},
		"./adapters/s3": {
			"import": {
				"types": "./dist/adapters/s3-presigned.d.ts",
				"default": "./dist/adapters/s3-presigned.js"
			},
			"require": {
				"types": "./dist/cjs/adapters/s3-presigned.d.cts",
				"default": "./dist/adapters/s3-presigned.cjs"
			}
		},
		"./adapters/s3-multipart": {
			"import": {
				"types": "./dist/adapters/s3-multipart.d.ts",
				"default": "./dist/adapters/s3-multipart.js"
			},
			"require": {
				"types": "./dist/cjs/adapters/s3-multipart.d.cts",
				"default": "./dist/adapters/s3-multipart.cjs"
			}
		},
		"./providers/unsplash": {
			"import": {
				"types": "./dist/sources/unsplash/index.d.ts",
				"default": "./dist/sources/unsplash/index.js"
			},
			"require": {
				"types": "./dist/cjs/sources/unsplash/index.d.cts",
				"default": "./dist/sources/unsplash/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"meta",
		"i18n"
	],
	"license": "MIT",
	"sideEffects": false,
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@puckeditor/core": "^0.22.1",
		"react": ">=19.2.0",
		"react-dom": ">=19.2.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"react-dom": {
			"optional": false
		},
		"@puckeditor/core": {
			"optional": false
		}
	},
	"dependencies": {
		"@anvilkit/core": "workspace:*",
		"@anvilkit/ir": "workspace:*",
		"@anvilkit/ui": "workspace:*",
		"@anvilkit/utils": "workspace:*",
		"lucide-react": "^1.21.0"
	},
	"scripts": {
		"build": "rslib build --lib esm && rslib build --lib cjs --no-clean",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json biome.json tsconfig.json rslib.config.ts vitest.config.ts src meta",
		"format": "pnpm exec biome check --write package.json biome.json tsconfig.json rslib.config.ts vitest.config.ts src meta",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"publint": "publint",
		"check:publint": "publint",
		"check:circular": "madge --circular --extensions ts src/",
		"check:peer-deps": "node ./scripts/check-peer-deps.mjs",
		"check:ui-dist": "node ./scripts/check-ui-dist.mjs",
		"check:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
		"check:api-snapshot": "node ./scripts/check-api-snapshot.mjs",
		"check:all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm check:ui-dist && pnpm check:publint && pnpm check:circular && pnpm check:peer-deps && pnpm check:bundle-budget && pnpm check:api-snapshot",
		"size": "size-limit"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@anvilkit/vitest-config": "workspace:*",
		"@puckeditor/core": "^0.22.1",
		"@rslib/core": "^0.23.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "19.2.3",
		"axe-core": "4.11.3",
		"esbuild": "^0.28.1",
		"happy-dom": "^20.8.9",
		"madge": "^8.0.0",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typedoc": "^0.28.20",
		"typescript": "7.0.2",
		"vitest": "^4.1.10",
		"vitest-axe": "^0.1.0"
	}
}
