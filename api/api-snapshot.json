	"packageName": "@anvilkit/plugin-asset-manager",
	"readme": [
		{
			"kind": "text",
			"text": "# "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-asset-manager`"
		},
		{
			"kind": "text",
			"text": "\n\nHeadless asset upload plugin for Anvilkit Studio.\n\n## What it ships\n\n- "
		},
		{
			"kind": "code",
			"text": "`createAssetManagerPlugin(options)`"
		},
		{
			"kind": "text",
			"text": " for Studio registration and runtime upload handling.\n- "
		},
		{
			"kind": "code",
			"text": "`createAssetRegistry()`"
		},
		{
			"kind": "text",
			"text": " for storing validated asset metadata by "
		},
		{
			"kind": "code",
			"text": "`id`"
		},
		{
			"kind": "text",
			"text": ".\n- "
		},
		{
			"kind": "code",
			"text": "`./ui`"
		},
		{
			"kind": "text",
			"text": " React components for a host-rendered upload button and asset browser.\n- Reference upload adapters for tests and demos.\n\n## Trust model\n\n"
		},
		{
			"kind": "code",
			"text": "`UploadAdapter.url`"
		},
		{
			"kind": "text",
			"text": " is treated as untrusted input. Every adapter response is validated through "
		},
		{
			"kind": "code",
			"text": "`validateUploadResult()`"
		},
		{
			"kind": "text",
			"text": " before it reaches the registry or IR-shaped data, with a default allowlist of "
		},
		{
			"kind": "code",
			"text": "`http`"
		},
		{
			"kind": "text",
			"text": ", "
		},
		{
			"kind": "code",
			"text": "`https`"
		},
		{
			"kind": "text",
			"text": ", and "
		},
		{
			"kind": "code",
			"text": "`blob`"
		},
		{
			"kind": "text",
			"text": ".\n\n## Entry points\n\n- "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-asset-manager`"
		},
		{
			"kind": "text",
			"text": " — headless runtime, validation, adapters, errors.\n- "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-asset-manager/ui`"
		},
		{
			"kind": "text",
			"text": " — React UI components.\n- "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-asset-manager/testing`"
		},
		{
			"kind": "text",
			"text": " — helpers for integration tests."
		}
	],
